# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามต้องการ
# (server.js จะโหลด .env อัตโนมัติผ่าน dotenv)

# พอร์ตที่เซิร์ฟเวอร์รัน
PORT=3000

# เบอร์/เลขบัตรประชาชนพร้อมเพย์ที่รับเงิน
PROMPTPAY_ID=0634284604

# สัญลักษณ์สกุลเงิน
CURRENCY=฿

# คีย์แอดมิน (เว้นว่าง = ไม่บังคับ) — ใช้ป้องกันการแก้ตั้งค่า/ล้างข้อมูลจากภายนอก
# ถ้าเปิดให้คนนอกเข้าถึงได้ ควรตั้งค่านี้
ADMIN_KEY=

# ---- ตรวจสลิป (OCR) ----
# โฟลเดอร์ traineddata แบบ offline (เว้นว่าง = โหลดจาก CDN ครั้งแรกแล้วแคชเอง)
TESSDATA_PATH=
# timeout การอ่าน OCR ต่อรูป (มิลลิวินาที)
OCR_TIMEOUT_MS=20000

# ---- เสียง ElevenLabs ----
# คีย์จาก ElevenLabs (เว้นว่าง = ใช้เสียงสังเคราะห์ของเบราว์เซอร์แทน)
ELEVENLABS_API_KEY=
# โมเดล (ดีฟอลต์รองรับภาษาไทย)
ELEVENLABS_MODEL=eleven_multilingual_v2
